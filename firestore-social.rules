rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isValidText(text) {
      return text is string &&
             text.size() > 0 &&
             text.size() <= 1000 &&
             !text.matches('.*[<>].*');
    }

    function isDeveloper() {
      return request.auth != null && (
        request.auth.uid == 'ukiyo' ||
        request.auth.token.email == 'ukiyo@rekindle.ink'
      );
    }

    function isModerator() {
      return request.auth != null && request.auth.token.moderator == true;
    }

    // --- TOPICS ---
    match /topics/{topicId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.resource.data.authorId == request.auth.uid &&
                       isValidText(request.resource.data.title);
      allow update: if request.auth != null && (
        (resource.data.authorId == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'lastActive']))
      );
      allow delete: if request.auth != null && (resource.data.authorId == request.auth.uid || isModerator() || isDeveloper());
    }

    match /topics/{topicId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.authorId == request.auth.uid &&
                       isValidText(request.resource.data.body);
      allow delete: if request.auth != null && (resource.data.authorId == request.auth.uid || isModerator() || isDeveloper());
    }

    // --- NEIGHBOURHOOD POSTS ---
    match /neighbourhood_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.resource.data.uid == request.auth.uid &&
                       isValidText(request.resource.data.text);
      allow update: if request.auth != null && (
        (resource.data.uid == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'lastActive']))
      );
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isModerator() || isDeveloper());
    }

    match /neighbourhood_posts/{postId}/comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
                       request.resource.data.uid == request.auth.uid &&
                       isValidText(request.resource.data.text);
      allow delete: if request.auth != null && (resource.data.uid == request.auth.uid || isModerator() || isDeveloper());
    }
  }
}
